<UserControl x:Class="QuestEditor.QuestCanvas.QuestCanvasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuestEditor.QuestCanvas"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label 
            Grid.Row="0"
            FontWeight="Bold"
            Content="{Binding ExplorerVM.SelectedQuestTag}"
            Foreground="{Binding ExplorerVM.QuestNameColor}"
            MinHeight="75"
            Height="Auto"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Bottom"
            Padding="4,4,4,4"/>

        <ScrollViewer Grid.Row="1"                               
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Background="{Binding CanvasBorderBrush}"
                    Padding="4">

            <ItemsControl ItemsSource="{Binding CanvasItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="{Binding CanvasBackgroundBrush}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="FrameworkElement">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>

        </ScrollViewer>

        <ScrollViewer
            Grid.Row="2" 
            Margin="8,8,8,8"                    
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
        <TextBox 
            AcceptsReturn="true"
            AcceptsTab="true"
            MinLines="4"
            MaxLength="2000"
            TextWrapping="Wrap"
            />

        </ScrollViewer>
    </Grid>

</UserControl>
