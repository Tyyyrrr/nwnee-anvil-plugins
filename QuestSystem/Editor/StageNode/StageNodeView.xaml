<UserControl x:Class="QuestEditor.StageNode.StageNodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuestEditor.StageNode"
             xmlns:propList="clr-namespace:QuestEditor.PropertyList"
             xmlns:objective="clr-namespace:QuestEditor.ObjectiveBox"
             xmlns:reward="clr-namespace:QuestEditor.RewardBox"
             mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <DataTemplate DataType="{x:Type propList:PropertyListViewModel}">
                <propList:PropertyListView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type objective:ObjectiveBoxViewModel}">
                <objective:ObjectiveBoxView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type reward:RewardBoxViewModel}">
                <reward:RewardBoxView />
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderThickness="4" Background="LightBlue" BorderBrush="DarkBlue" CornerRadius="7">
    <StackPanel Background="DimGray">
        <Label Content="{Binding StageIDLabelDisplay}"/>

        <Expander Header="Journal" IsExpanded="{Binding JournalEntryExpanded}" ToolTip="Text shown above list of objectives in the player's journal.">
            <TextBox
                MinWidth="50"
                Text="{Binding JournalEntry, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
        </Expander>

        <StackPanel Orientation="Horizontal">
            <Label Content="New objective type:"/>
            <ComboBox ItemsSource="{Binding ObjectiveTypeNames}" SelectedItem="{Binding SelectedNewObjectiveTypeName, Mode=OneWayToSource}" IsReadOnly="true" IsEditable="false" />
        </StackPanel>
        

        <StackPanel Orientation="Horizontal">
            <Button Content="New objective" Command="{Binding NewObjectiveCommand}"
                CommandParameter="{Binding NewObjectiveType}"/>
            <Button Content="Delete objective" Command="{Binding DeleteObjectiveCommand}"/>
        </StackPanel>

        <ListBox ItemsSource="{Binding Objectives}" SelectedItem="{Binding SelectedObjective}"/>

        <reward:RewardBoxView DataContext="{Binding Reward}"/>

        <StackPanel Orientation="Horizontal" ToolTip="Jump to given stage after completing all non-optional objectives (Optional objectives can have their own NextStageID set to 0 or greater. Those have higher priority!)">
            <Label Content="{Binding NextStageIDLabelDisplay}" />
            <TextBox Text="{Binding NextStageID, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                Foreground="{Binding NextStageIDColor}"/>
        </StackPanel>
    </StackPanel>
    </Border>

</UserControl>
